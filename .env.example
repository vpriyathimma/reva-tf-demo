# Local-dev fallback for config. In production TrueFoundry sends these in the
# per-request `config` object (set in the dashboard integration form), which
# takes precedence over anything here.

# --- NEW eval contract (customer.dev / dv06) — this branch's target ---
# Amit's new AI Evaluation API. Point here once the app exists in customer.dev
# and the entity-sync platform issue is fixed (Amit will give the headsup).
# POLICYSTORE_ID + AUTH_TOKEN come from OUR customer.dev app (not Amit's curl,
# which is for the underwriter-copilot topology). ORIGIN is customer.dev.
REVA_PDP_URL=https://api.dv06.dev.reva.ai/pdp/access/v1/ai/evaluation
REVA_POLICYSTORE_ID=<customer.dev policy store id>
REVA_AUTH_TOKEN=<customer.dev auth token>
REVA_PDP_ORIGIN=https://customer.dev.reva.ai

# --- previous target (customer.preview / pr06), kept for revert ---
# REVA_PDP_URL=https://api.pr06.preview.reva.ai/pdp/access/v1/ai/evaluation
# REVA_POLICYSTORE_ID=c5a1339b-15bc-403d-a481-e4ac42bc2b40
# REVA_PDP_ORIGIN=https://demo.preview.reva.ai

# --- defaults ---
REVA_PDP_TIMEOUT=5.0

# enforce | log | monitor
REVA_HOOK_MODE=enforce

# Which Cedar vocabulary to speak to the PDP:
#   vanilla  -> User/CallModel/Model (the LiteLLM demo's policy store)
#   agent_v5 -> Agent/invokeModel/Model + SharedContext + conversation/hops
#               (the new AI Evaluation contract — this branch uses this)
REVA_SCHEMA_MODE=agent_v5

# agent_v5 only: the Agent id used as the request principal. Normally arrives
# per-request in X-TFY-METADATA {"agent_id": "..."}; this is the fallback.
# REVA_AGENT_ID=billing-support-agent
# REVA_ENVIRONMENT=PROD

# open | closed. Leave unset to derive from mode:
#   enforce -> closed (deny on PDP error)
#   log/monitor -> open (allow on PDP error)
# REVA_FAIL_MODE=closed

# Debug: logs the FULL incoming TrueFoundry payload (context + metadata keys)
# so you can confirm what TF actually forwards — especially whether team/tier
# arrive and under which keys. Payloads include the prompt, so keep this OFF
# in production. Turn on only for the first TF integration test.
# REVA_DEBUG=1
